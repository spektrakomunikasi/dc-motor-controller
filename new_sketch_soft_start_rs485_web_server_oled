void setupWeb(){
  server.on("/", HTTP_GET, handleRoot);

  server.on("/api/status", HTTP_GET, [](){
    char json[320];
    snprintf(json, sizeof(json),
      "{\"state\":\"%s\",\"vin\":%.2f,\"vout\":%.2f,\"i\":%.2f,\"fault\":%u,\"ilim\":%.2f,\"gscale\":%.3f}",
      getStateString(motorState), supplyVoltage, outputVoltage, motorCurrent, faultCode, maxCurrentLimit, globalScale
    );
    server.sendHeader("Cache-Control","no-store, no-cache, must-revalidate, max-age=0");
    server.send(200, "application/json", json);
  });

  server.on("/api/scale", HTTP_GET, [](){
    if(!server.hasArg("v")){ server.send(400,"application/json","{\"ok\":false,\"msg\":\"need v\"}"); return; }
    float v=server.arg("v").toFloat();
    if(v<0.50f||v>1.50f){ server.send(400,"application/json","{\"ok\":false,\"msg\":\"range 0.50..1.50\"}"); return; }
    globalScale=v; saveSettings(); server.send(200,"application/json","{\"ok\":true}");
  });

  server.on("/api/limit", HTTP_GET, [](){
    if(!server.hasArg("v")){ server.send(400,"application/json","{\"ok\":false,\"msg\":\"need v\"}"); return; }
    float v=server.arg("v").toFloat();
    if(v<1.0f||v>10.0f){ server.send(400,"application/json","{\"ok\":false,\"msg\":\"range 1..10\"}"); return; }
    maxCurrentLimit=v; saveSettings();
    String out="{\"ok\":true,\"ilim\":"+String(maxCurrentLimit,2)+"}";
    server.send(200,"application/json",out);
  });

  server.on("/api/zero", HTTP_GET, [](){
    if(motorState==STATE_IDLE){ calibrateCurrentOffset(); saveSettings(); server.send(200,"application/json","{\"ok\":true}"); }
    else server.send(200,"application/json","{\"ok\":false,\"msg\":\"must be IDLE\"}");
  });

  server.on("/api/control", HTTP_POST, [](){
    if(!server.hasArg("plain")){ server.send(400,"application/json","{\"error\":\"no body\"}"); return; }
    String b=server.arg("plain");

    if(b.indexOf("start")>=0){
      if(motorState==STATE_IDLE){
        motorState=STATE_SOFT_START;
        stateStartTime=millis();
        faultCode=0;
        overCurrentStart=0;
        startSnapDone=false;
        rampPwmFloat = voltToPwm(RAMP_START_V);
      }
    }else if(b.indexOf("stop")>=0){
      if(motorState!=STATE_IDLE && motorState!=STATE_SOFT_STOP){
        motorState=STATE_SOFT_STOP;
        stateStartTime=millis();
      }
    }else if(b.indexOf("reset_fault")>=0){
      if(motorState==STATE_FAULT){
        faultCode=0;
        motorState=STATE_IDLE;
        overCurrentStart=0;
        digitalWrite(ALARM_OUTPUT_PIN,LOW);
      }
    }
    server.send(200,"application/json","{\"status\":\"ok\"}");
  });

  server.begin();
}

// ================= SETUP LOOP =================
void setup(){
  Serial.begin(115200);
  delay(200);

  Wire.begin(I2C_SDA, I2C_SCL);
  Wire.setClock(400000);

  display.begin(SSD1306_SWITCHCAPVCC,0x3C);
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(0,0);
  display.println("FINAL RELEASE");
  display.display();

  tempSensor.begin();
  if(tempSensor.getAddress(tempAddress,0)) tempSensor.setResolution(tempAddress,12);

  pinMode(PWM_VOLTAGE_PIN,OUTPUT);
  pinMode(RELAY_PIN,OUTPUT);
  pinMode(ALARM_OUTPUT_PIN,OUTPUT);
  pinMode(BUTTON_START,INPUT_PULLUP);
  pinMode(BUTTON_STOP,INPUT_PULLUP);
  pinMode(KONTAKTOR_INPUT,INPUT_PULLUP);
  pinMode(LED_GREEN,OUTPUT);
  pinMode(LED_RED,OUTPUT);
  pinMode(LED_YELLOW,OUTPUT);

  digitalWrite(RELAY_PIN,LOW);
  digitalWrite(ALARM_OUTPUT_PIN,LOW);

  ledcSetup(PWM_CHANNEL,PWM_FREQUENCY,PWM_RESOLUTION);
  ledcAttachPin(PWM_VOLTAGE_PIN,PWM_CHANNEL);
  ledcWrite(PWM_CHANNEL,255);

  analogSetAttenuation(ADC_11db);
  analogReadResolution(12);

  EEPROM.begin(256);
  loadSettings();
  calibrateCurrentOffset();

  WiFi.mode(WIFI_AP);
  WiFi.softAP("SoftStarter-Config","spektra2026");

  setupWeb();
  setupModbus();
}

void loop(){
  bool startPressed=(digitalRead(BUTTON_START)==LOW);
  bool stopPressed=(digitalRead(BUTTON_STOP)==LOW);

  if(startPressed && motorState==STATE_IDLE){
    motorState=STATE_SOFT_START;
    stateStartTime=millis();
    faultCode=0;
    overCurrentStart=0;
    startSnapDone=false;
    rampPwmFloat = voltToPwm(RAMP_START_V);
  }
  if(stopPressed && motorState!=STATE_IDLE && motorState!=STATE_SOFT_STOP){
    motorState=STATE_SOFT_STOP;
    stateStartTime=millis();
  }

  server.handleClient();
  mb.task();

  if(millis()-lastSensorRead>=100){
    readAllSensors();
    updateModbusRegs();
    processModbusCommands();
    lastSensorRead=millis();
  }

  handleMotorState();
  checkFaults();
  handleFaultAutoRetry();
  updateLEDs();

  if(millis()-lastDisplay>=250){
    updateDisplay();
    lastDisplay=millis();
  }

  delay(1);
}
