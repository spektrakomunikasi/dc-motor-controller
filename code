// =============================================================================
// GLOBAL STATE
// =============================================================================
String apName = "";
float currentFiltered = 0.0f;
float voltageFiltered = 24.0f;
float currentThreshold = CURRENT_DEFAULT;
uint8_t softStartDuration = SOFT_START_DEFAULT_TIME;

enum MotorState { STOPPED, SOFT_START_RAMP, RUNNING, OVERCURRENT_CUTOFF };
MotorState motorState = STOPPED;
bool relayMotorOn = false;
bool relaySoftStartOn = false;
uint32_t softStartStartMs = 0;

uint32_t lastDisplayMs = 0;
uint32_t lastMonitorMs = 0;
uint32_t lastStartButtonMs = 0;
uint32_t lastStopButtonMs = 0;
bool startButtonWasPressed = false;
bool stopButtonWasPressed = false;

// =============================================================================
// SENSOR FUNCTIONS
// =============================================================================

float readCurrentRaw() {
    uint32_t sum = 0;
    for (uint8_t i = 0; i < 16; i++) sum += analogRead(ACS712_PIN);
    float adcVal = sum / 16.0f;
    float voltageMv = adcVal * ADC_MV_PER_STEP;
    float currentAmps = (voltageMv - ACS712_ZERO_OFFSET_MV) / ACS712_SENSITIVITY;
    return (currentAmps < 0.0f) ? 0.0f : currentAmps;
}

float readVoltageRaw() {
    uint32_t sum = 0;
    for (uint8_t i = 0; i < 16; i++) sum += analogRead(VOLTAGE_PIN);
    float adcVal = sum / 16.0f;
    float voltageMv = adcVal * ADC_MV_PER_STEP;
    float voltageSupply = voltageMv * VOLTAGE_DIVIDER_RATIO;
    return (voltageSupply < 0.0f) ? 0.0f : voltageSupply;
}

// =============================================================================
// RELAY & BUTTON FUNCTIONS
// =============================================================================

void setRelayMotor(bool on) {
    relayMotorOn = on;
    digitalWrite(RELAY_CUTOFF_PIN, on ? HIGH : LOW);
}

void setRelaySoftStart(bool on) {
    relaySoftStartOn = on;
    digitalWrite(RELAY_SOFTSTART_PIN, on ? HIGH : LOW);
}

void stopMotor() {
    setRelayMotor(false);
    setRelaySoftStart(false);
    motorState = STOPPED;
}

bool isPushButtonPressed(uint8_t buttonPin, uint32_t& lastPressMs, bool& wasPressed) {
    bool reading = digitalRead(buttonPin);
    uint32_t now = millis();
    if (reading == LOW && !wasPressed && (now - lastPressMs > BUTTON_DEBOUNCE_MS)) {
        lastPressMs = now;
        wasPressed = true;
        return true;
    }
    if (reading == HIGH) wasPressed = false;
    return false;
}

// =============================================================================
// SOFT START FUNCTIONS
// =============================================================================

void startSoftStart(uint8_t durationSec) {
    if (durationSec < SOFT_START_MIN_TIME) durationSec = SOFT_START_MIN_TIME;
    if (durationSec > SOFT_START_MAX_TIME) durationSec = SOFT_START_MAX_TIME;
    softStartDuration = durationSec;
    softStartStartMs = millis();
    motorState = SOFT_START_RAMP;
    setRelayMotor(true);
    setRelaySoftStart(false);
    Serial.printf("[Motor] ▶️ Soft start: %d sec\n", durationSec);
}

uint8_t getSoftStartProgress() {
    if (motorState != SOFT_START_RAMP) return (motorState == RUNNING) ? 100 : 0;
    uint32_t elapsed = millis() - softStartStartMs;
    uint32_t total = (uint32_t)softStartDuration * 1000UL;
    if (elapsed >= total) return 100;
    return (uint8_t)((elapsed * 100UL) / total);
}

// =============================================================================
// WIFI & STORAGE
// =============================================================================

void buildAPName() {
    uint8_t mac[6];
    WiFi.macAddress(mac);
    char suffix[9];
    snprintf(suffix, sizeof(suffix), "%02X%02X%02X%02X", mac[2], mac[3], mac[4], mac[5]);
    apName = String(AP_SSID_PREFIX) + suffix;
}

// =============================================================================
// OLED DISPLAY
// =============================================================================

void updateDisplay() {
    uint32_t now = millis();
    if (now - lastDisplayMs < DISPLAY_UPDATE_MS) return;
    lastDisplayMs = now;

    display.clearDisplay();
    display.setTextSize(1);
    display.setTextColor(SSD1306_WHITE);

    display.setCursor(0, 0);
    display.println("MOTOR v5.0");
    display.drawLine(0, 9, 127, 9, SSD1306_WHITE);
    
    display.setCursor(0, 12);
    display.printf("V:%.1f  I:%.2f", voltageFiltered, currentFiltered);
    
    display.setCursor(0, 22);
    display.printf("Lim:%.0f  SS:%d", currentThreshold, softStartDuration);
    
    display.setCursor(0, 32);
    display.printf("Motor:");
    switch (motorState) {
        case STOPPED: display.println(" STOP"); break;
        case SOFT_START_RAMP: display.printf(" RAMP%d%%", getSoftStartProgress()); break;
        case RUNNING: display.println(" RUN"); break;
        case OVERCURRENT_CUTOFF: display.println(" OVR"); break;
    }
    
    display.setCursor(0, 42);
    display.printf("R1:%s R2:%s", relayMotorOn ? "ON" : "OFF", relaySoftStartOn ? "ON" : "OFF");
    
    display.setCursor(0, 52);
    display.println("S1=START   S2=STOP");
    
    display.drawLine(0, 61, 127, 61, SSD1306_WHITE);
    display.display();
}

// =============================================================================
// WEB SERVER ROUTES
// =============================================================================

void setupWebRoutes() {
    webServer.on("/", HTTP_GET, [](AsyncWebServerRequest* req) {
        req->send(200, "text/html; charset=utf-8", DASHBOARD_HTML);
    });

    webServer.on("/api/status", HTTP_GET, [](AsyncWebServerRequest* req) {
        JsonDocument doc;
        doc["voltage"] = voltageFiltered;
        doc["current"] = currentFiltered;
        doc["threshold"] = currentThreshold;
        doc["relay1"] = relayMotorOn;
        doc["relay2"] = relaySoftStartOn;
        doc["soft_start_progress"] = getSoftStartProgress();
        doc["soft_start_time"] = (int)softStartDuration;
        doc["uptime_ms"] = millis();
        const char* stateStr = "UNKNOWN";
        switch (motorState) {
            case STOPPED: stateStr = "STOPPED"; break;
            case SOFT_START_RAMP: stateStr = "RAMP"; break;
            case RUNNING: stateStr = "RUNNING"; break;
            case OVERCURRENT_CUTOFF: stateStr = "OVERCURRENT"; break;
        }
        doc["motor_state"] = stateStr;
        String body;
        serializeJson(doc, body);
        req->send(200, "application/json", body);
    });

    webServer.on("/api/threshold", HTTP_POST, [](AsyncWebServerRequest* req) {
        if (req->_tempObject) {
            String* resp = reinterpret_cast<String*>(req->_tempObject);
            req->send(200, "application/json", *resp);
            delete resp;
            req->_tempObject = nullptr;
        }
    }, nullptr, [](AsyncWebServerRequest* req, uint8_t* data, size_t len, size_t index, size_t total) {
        if (index == 0) req->_tempObject = new String();
        if (index + len == total) {
            String body((char*)data, len);
            JsonDocument doc;
            deserializeJson(doc, body);
            float val = doc["value"] | CURRENT_DEFAULT;
            if (val < CURRENT_MIN) val = CURRENT_MIN;
            if (val > CURRENT_MAX) val = CURRENT_MAX;
            currentThreshold = val;
            prefs.begin(NVS_NAMESPACE, false);
            prefs.putFloat(PREF_KEY_THRESHOLD, currentThreshold);
            prefs.end();
            Serial.printf("[Threshold] %.1f A\n", val);
            String* resp = reinterpret_cast<String*>(req->_tempObject);
            *resp = "{\"success\":true,\"threshold\":" + String(val, 1) + "}";
        }
    });

    webServer.on("/api/soft-start-time", HTTP_POST, [](AsyncWebServerRequest* req) {
        if (req->_tempObject) {
            String* resp = reinterpret_cast<String*>(req->_tempObject);
            req->send(200, "application/json", *resp);
            delete resp;
            req->_tempObject = nullptr;
        }
    }, nullptr, [](AsyncWebServerRequest* req, uint8_t* data, size_t len, size_t index, size_t total) {
        if (index == 0) req->_tempObject = new String();
        if (index + len == total) {
            String body((char*)data, len);
            JsonDocument doc;
            deserializeJson(doc, body);
            uint8_t val = doc["value"] | SOFT_START_DEFAULT_TIME;
            if (val < SOFT_START_MIN_TIME) val = SOFT_START_MIN_TIME;
            if (val > SOFT_START_MAX_TIME) val = SOFT_START_MAX_TIME;
            softStartDuration = val;
            prefs.begin(NVS_NAMESPACE, false);
            prefs.putUChar(PREF_KEY_SOFT_START, softStartDuration);
            prefs.end();
            Serial.printf("[SoftStart] %d sec\n", val);
            String* resp = reinterpret_cast<String*>(req->_tempObject);
            *resp = "{\"success\":true,\"soft_start_time\":" + String(val) + "}";
        }
    });

    webServer.on("/api/relay/motor", HTTP_POST, [](AsyncWebServerRequest* req) {
        if (req->_tempObject) {
            String* resp = reinterpret_cast<String*>(req->_tempObject);
            req->send(200, "application/json", *resp);
            delete resp;
            req->_tempObject = nullptr;
        }
    }, nullptr, [](AsyncWebServerRequest* req, uint8_t* data, size_t len, size_t index, size_t total) {
        if (index == 0) req->_tempObject = new String();
        if (index + len == total) {
            String body((char*)data, len);
            JsonDocument doc;
            deserializeJson(doc, body);
            bool state = doc["state"] | false;
            if (state) {
                startSoftStart(softStartDuration);
            } else {
                stopMotor();
            }
            String* resp = reinterpret_cast<String*>(req->_tempObject);
            *resp = "{\"success\":true}";
        }
    });

    webServer.onNotFound([](AsyncWebServerRequest* req) {
        req->send(404, "text/plain", "Not found");
    });
}

// =============================================================================
// MOTOR STATE MACHINE
// =============================================================================

void updateMotorState() {
    uint32_t now = millis();
    if (now - lastMonitorMs < MONITOR_UPDATE_MS) return;
    lastMonitorMs = now;

    float rawCurrent = readCurrentRaw();
    currentFiltered = CURRENT_EMA_ALPHA * rawCurrent + (1.0f - CURRENT_EMA_ALPHA) * currentFiltered;
    
    float rawVoltage = readVoltageRaw();
    voltageFiltered = VOLTAGE_EMA_ALPHA * rawVoltage + (1.0f - VOLTAGE_EMA_ALPHA) * voltageFiltered;

    switch (motorState) {
        case SOFT_START_RAMP: {
            if (currentFiltered >= currentThreshold) {
                stopMotor();
                motorState = OVERCURRENT_CUTOFF;
                Serial.printf("[Motor] ⚠️ OVERCURRENT: %.2fA\n", currentFiltered);
            } else if (getSoftStartProgress() >= 100) {
                setRelaySoftStart(true);
                motorState = RUNNING;
                Serial.println("[Motor] ✅ RUNNING");
            }
            break;
        }
        case RUNNING: {
            if (currentFiltered >= currentThreshold) {
                stopMotor();
                motorState = OVERCURRENT_CUTOFF;
                Serial.printf("[Motor] ⚠️ OVERCURRENT: %.2fA\n", currentFiltered);
            }
            break;
        }
        default:
            break;
    }
}

// =============================================================================
// SETUP
// =============================================================================

void setup() {
    Serial.begin(115200);
    delay(500);
    
    Serial.println("\n╔════════════════════════════════════════════════════╗");
    Serial.println("║   ESP32 MOTOR CONTROLLER v5.0 - FINAL READY       ║");
    Serial.println("╚════════════════════════════════════════════════════╝\n");

    pinMode(RELAY_CUTOFF_PIN, OUTPUT);
    pinMode(RELAY_SOFTSTART_PIN, OUTPUT);
    pinMode(PUSH_BUTTON_START, INPUT_PULLUP);
    pinMode(PUSH_BUTTON_STOP, INPUT_PULLUP);
    digitalWrite(RELAY_CUTOFF_PIN, LOW);
    digitalWrite(RELAY_SOFTSTART_PIN, LOW);

    analogReadResolution(12);
    analogSetAttenuation(ADC_11db);

    Wire.begin(I2C_SDA, I2C_SCL);
    if (!display.begin(SSD1306_SWITCHCAPVCC, OLED_ADDR)) {
        Serial.println("[OLED] Init failed!");
    } else {
        display.clearDisplay();
        display.setTextSize(1);
        display.setTextColor(SSD1306_WHITE);
        display.setCursor(0, 20);
        display.println("MOTOR v5.0");
        display.setCursor(0, 36);
        display.println("Starting...");
        display.display();
    }

    prefs.begin(NVS_NAMESPACE, true);
    currentThreshold = prefs.getFloat(PREF_KEY_THRESHOLD, CURRENT_DEFAULT);
    softStartDuration = prefs.getUChar(PREF_KEY_SOFT_START, SOFT_START_DEFAULT_TIME);
    prefs.end();

    buildAPName();
    WiFi.mode(WIFI_AP_STA);
    WiFi.disconnect(true);
    WiFi.mode(WIFI_AP);
    
    IPAddress apIP;
    apIP.fromString(AP_IP_ADDR);
    IPAddress gateway;
    gateway.fromString(AP_GATEWAY);
    IPAddress subnet;
    subnet.fromString(AP_SUBNET);
    
    WiFi.softAPConfig(apIP, gateway, subnet);
    WiFi.softAP(apName.c_str(), AP_PASSWORD);
    
    Serial.printf("SSID: %s | Pass: %s | IP: %s\n", apName.c_str(), AP_PASSWORD, AP_IP_ADDR);

    setupWebRoutes();
    webServer.begin();
    Serial.println("✅ Ready! Visit http://192.168.4.1\n");
}

// =============================================================================
// MAIN LOOP
// =============================================================================

void loop() {
    updateMotorState();

    if (isPushButtonPressed(PUSH_BUTTON_START, lastStartButtonMs, startButtonWasPressed)) {
        if (motorState == STOPPED || motorState == OVERCURRENT_CUTOFF) {
            startSoftStart(softStartDuration);
            Serial.println("[S1] START pressed");
        }
    }

    if (isPushButtonPressed(PUSH_BUTTON_STOP, lastStopButtonMs, stopButtonWasPressed)) {
        if (motorState != STOPPED) {
            stopMotor();
            Serial.println("[S2] STOP pressed");
        }
    }

    updateDisplay();
}
